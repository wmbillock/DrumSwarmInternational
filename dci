#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════════╗
# ║                      DCI SWARM — CLI                            ║
# ║    Unified entry point for the DCI Swarm orchestration engine   ║
# ╠══════════════════════════════════════════════════════════════════╣
# ║                                                                 ║
# ║  ./dci ten-hut          Everything — backend, frontend, TMUX    ║
# ║  ./dci parade-rest      Halt all services — at ease             ║
# ║  ./dci mark-time        TMUX dashboard — keep time, eyes front  ║
# ║  ./dci forward-march    Backend only — step off                 ║
# ║  ./dci company-front    Frontend only — dress the line          ║
# ║  ./dci run-through      Run the test suite                      ║
# ║  ./dci check-step       Show status of all services             ║
# ║  ./dci set-the-field    Initialize the database                 ║
# ║  ./dci horns-up         Show this help                          ║
# ║                                                                 ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Environment:
#   DCI_PORT      Backend port (default: 8000)
#   DCI_SESSION   TMUX session name (default: dci-swarm)

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
VENV_DIR="$PROJECT_ROOT/.venv"
BACKEND_PORT="${DCI_PORT:-8000}"
FRONTEND_DIR="$PROJECT_ROOT/frontend"
SCRIPTS_DIR="$PROJECT_ROOT/scripts"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

log_info()  { echo -e "${GREEN}[corps]${NC} $1"; }
log_warn()  { echo -e "${YELLOW}[corps]${NC} $1"; }
log_error() { echo -e "${RED}[corps]${NC} $1"; }

# --- Helpers ---

activate_venv() {
    if [ -f "$VENV_DIR/bin/activate" ]; then
        source "$VENV_DIR/bin/activate"
    else
        log_warn "No virtualenv found at $VENV_DIR. Run: python3 -m venv .venv && pip install -e '.[dev]'"
    fi
}

ensure_node_modules() {
    if [ ! -d "$FRONTEND_DIR/node_modules" ]; then
        log_info "Equipment check — installing frontend dependencies..."
        (cd "$FRONTEND_DIR" && npm install)
    fi
}

kill_port() {
    local port=$1
    lsof -ti:"$port" 2>/dev/null | xargs kill -9 2>/dev/null || true
}

# --- Commands ---

cmd_ten_hut() {
    echo ""
    echo -e "${BOLD}  CORPS — TEN HUT!${NC}"
    echo ""
    log_info "Full corps reporting to the field"
    activate_venv
    ensure_node_modules

    # Clear the field
    kill_port "$BACKEND_PORT"
    kill_port 5173

    # Backend — brass line steps off
    cd "$PROJECT_ROOT"
    uvicorn backend.api.app:app --host 0.0.0.0 --port "$BACKEND_PORT" --reload \
        > "$PROJECT_ROOT/backend.log" 2>&1 &
    log_info "Backend on the field (PID: $!, port $BACKEND_PORT)"

    # Wait for the pit to tune up
    for i in $(seq 1 15); do
        if curl -s "http://localhost:$BACKEND_PORT/api/shows" >/dev/null 2>&1; then
            log_info "Backend is set"
            break
        fi
        sleep 1
    done

    # Frontend — guard takes the floor
    cd "$FRONTEND_DIR"
    npm run dev > "$PROJECT_ROOT/frontend.log" 2>&1 &
    log_info "Frontend on the field (PID: $!, port 5173)"

    log_info "Opening monitoring dashboard..."
    echo ""

    # Hand off to TMUX dashboard (replaces this process)
    exec bash "$SCRIPTS_DIR/monitoring/start_monitor.sh" start
}

cmd_parade_rest() {
    echo ""
    echo -e "${BOLD}  CORPS — PARADE REST${NC}"
    echo ""
    log_info "Standing down all sections..."

    # Kill TMUX session
    tmux kill-session -t "${DCI_SESSION:-dci-swarm}" 2>/dev/null && \
        log_info "TMUX dashboard dismissed" || true

    # Kill backend/frontend
    kill_port "$BACKEND_PORT" && log_info "Backend off the field" || true
    kill_port 5173 && log_info "Frontend off the field" || true

    log_info "Corps at rest. Dismissed."
    echo ""
}

cmd_mark_time() {
    echo ""
    echo -e "${BOLD}  MARK TIME — HUT!${NC}"
    echo ""
    if [ ! -f "$SCRIPTS_DIR/monitoring/start_monitor.sh" ]; then
        log_error "Monitoring scripts not found at $SCRIPTS_DIR/monitoring/"
        exit 1
    fi
    exec bash "$SCRIPTS_DIR/monitoring/start_monitor.sh" "${1:-start}"
}

cmd_forward_march() {
    echo ""
    echo -e "${BOLD}  FORWARD — MARCH!${NC}"
    echo ""
    log_info "Backend stepping off"
    activate_venv
    kill_port "$BACKEND_PORT"
    cd "$PROJECT_ROOT"
    uvicorn backend.api.app:app --host 0.0.0.0 --port "$BACKEND_PORT" --reload
}

cmd_company_front() {
    echo ""
    echo -e "${BOLD}  COMPANY — FRONT!${NC}"
    echo ""
    log_info "Frontend dressing the line"
    ensure_node_modules
    cd "$FRONTEND_DIR"
    npm run dev
}

cmd_run_through() {
    echo ""
    echo -e "${BOLD}  RUN-THROUGH${NC}"
    echo ""
    log_info "Full ensemble run — executing test suite"
    activate_venv
    cd "$PROJECT_ROOT"
    python -m pytest "${@:--v}"
}

cmd_check_step() {
    echo ""
    echo -e "${BOLD}  CHECK STEP${NC}"
    echo ""

    # Backend
    if curl -s "http://localhost:$BACKEND_PORT/api/shows" >/dev/null 2>&1; then
        echo -e "  Backend:    ${GREEN}on the field${NC}  (port $BACKEND_PORT)"
    else
        echo -e "  Backend:    ${RED}at rest${NC}"
    fi

    # Frontend
    if curl -s "http://localhost:5173" >/dev/null 2>&1; then
        echo -e "  Frontend:   ${GREEN}on the field${NC}  (port 5173)"
    else
        echo -e "  Frontend:   ${RED}at rest${NC}"
    fi

    # TMUX
    if tmux has-session -t "${DCI_SESSION:-dci-swarm}" 2>/dev/null; then
        echo -e "  Dashboard:  ${GREEN}marking time${NC}  (tmux: ${DCI_SESSION:-dci-swarm})"
    else
        echo -e "  Dashboard:  ${RED}at rest${NC}"
    fi

    echo ""
}

cmd_set_the_field() {
    echo ""
    echo -e "${BOLD}  SET THE FIELD${NC}"
    echo ""
    log_info "Laying out the coordinate grid..."
    activate_venv
    cd "$PROJECT_ROOT"

    # Run Alembic migrations first, then create any remaining tables
    if [ -f "alembic.ini" ]; then
        log_info "Running database migrations..."
        alembic upgrade head
    fi

    python -c "
from backend.database import create_db_engine, Base, init_db
engine = create_db_engine()
init_db(engine)
print('Field is set.')
"
}

cmd_resume_hut() {
    echo ""
    echo -e "${BOLD}  RESUME — HUT!${NC}"
    echo ""
    log_info "Restarting backend and frontend in place..."
    activate_venv
    ensure_node_modules

    # Kill existing processes on ports but leave tmux alone
    kill_port "$BACKEND_PORT" && log_info "Backend recycled" || true
    kill_port 5173 && log_info "Frontend recycled" || true
    sleep 1

    # Restart backend
    cd "$PROJECT_ROOT"
    uvicorn backend.api.app:app --host 0.0.0.0 --port "$BACKEND_PORT" --reload \
        > "$PROJECT_ROOT/backend.log" 2>&1 &
    log_info "Backend back on the field (PID: $!, port $BACKEND_PORT)"

    # Wait for backend
    for i in $(seq 1 15); do
        if curl -s "http://localhost:$BACKEND_PORT/api/shows" >/dev/null 2>&1; then
            log_info "Backend is set"
            break
        fi
        sleep 1
    done

    # Restart frontend
    cd "$FRONTEND_DIR"
    npm run dev > "$PROJECT_ROOT/frontend.log" 2>&1 &
    log_info "Frontend back on the field (PID: $!, port 5173)"

    echo ""
    log_info "Corps resumed. TMUX session untouched."
    echo ""
}

cmd_drill() {
    echo ""
    echo -e "${BOLD}  DRILL — REP IT OUT!${NC}"
    echo ""
    log_info "Running calibration drill"
    activate_venv
    cd "$PROJECT_ROOT"
    python -m backend.cli.drill "$@"
}

cmd_horns_up() {
    echo ""
    echo -e "${BOLD}  ╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}  ║              DRUM SWARM INTERNATIONAL                   ║${NC}"
    echo -e "${BOLD}  ║          Agent Orchestration Engine                     ║${NC}"
    echo -e "${BOLD}  ╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${BOLD}  Commands:${NC}"
    echo ""
    echo -e "  ${GREEN}ten-hut${NC}          Full stack + monitoring dashboard — everything"
    echo -e "  ${GREEN}parade-rest${NC}      Halt all services — stand down"
    echo -e "  ${GREEN}mark-time${NC}        Launch TMUX monitoring dashboard"
    echo -e "  ${GREEN}forward-march${NC}    Start backend API server only"
    echo -e "  ${GREEN}company-front${NC}    Start frontend dev server only"
    echo -e "  ${GREEN}run-through${NC}      Run the full test suite"
    echo -e "  ${GREEN}check-step${NC}       Show status of all services"
    echo -e "  ${GREEN}set-the-field${NC}    Initialize the database schema"
    echo -e "  ${GREEN}resume-hut${NC}       Restart backend + frontend, keep TMUX alive"
    echo -e "  ${GREEN}dress-center${NC}     Alias for resume-hut"
    echo -e "  ${GREEN}drill${NC}            Run a calibration drill (agent swarm on a task)"
    echo -e "  ${GREEN}horns-up${NC}         Show this help"
    echo ""
    echo -e "${BOLD}  Examples:${NC}"
    echo ""
    echo -e "  ${DIM}./dci ten-hut${NC}                   # Bring the full corps to attention"
    echo -e "  ${DIM}./dci mark-time${NC}                 # Open the TMUX press box"
    echo -e "  ${DIM}./dci drill -p 1${NC}                 # Run Euler problem #1"
    echo -e "  ${DIM}./dci drill -l 1,2,3${NC}             # Calibration loop on problems 1-3"
    echo -e "  ${DIM}./dci run-through -k scoring${NC}    # Run scoring tests only"
    echo -e "  ${DIM}./dci check-step${NC}                # Is the corps on the field?"
    echo -e "  ${DIM}./dci parade-rest${NC}               # Dismiss the corps"
    echo ""
    echo -e "${BOLD}  TMUX Hotkeys (inside mark-time session):${NC}"
    echo ""
    echo -e "  ${GREEN}prefix+s${NC}         Swarm menu (popup with all actions)"
    echo -e "  ${GREEN}prefix+1..6${NC}      Switch dashboard view (metrics/agents/logs/changes/memory/lifecycle)"
    echo -e "  ${GREEN}prefix+0${NC}         Focus Claude Code pane"
    echo -e "  ${GREEN}prefix+d${NC}         Focus Dashboard pane"
    echo -e "  ${GREEN}prefix+l${NC}         Focus Backend log pane"
    echo -e "  ${GREEN}prefix+;${NC}         Focus Frontend log pane"
    echo ""
    echo -e "${BOLD}  Environment:${NC}"
    echo ""
    echo -e "  DCI_PORT=8000               Backend port"
    echo -e "  DCI_SESSION=dci-swarm       TMUX session name"
    echo ""
}

# --- Main ---

case "${1:-horns-up}" in
    ten-hut)         cmd_ten_hut ;;
    parade-rest)     cmd_parade_rest ;;
    mark-time)       cmd_mark_time "${2:-start}" ;;
    forward-march)   cmd_forward_march ;;
    company-front)   cmd_company_front ;;
    run-through)     shift; cmd_run_through "$@" ;;
    check-step)      cmd_check_step ;;
    set-the-field)   cmd_set_the_field ;;
    resume-hut|dress-center) cmd_resume_hut ;;
    drill)           shift; cmd_drill "$@" ;;
    horns-up|-h|--help|help) cmd_horns_up ;;
    *)
        log_error "Unknown command: $1"
        echo ""
        cmd_horns_up
        exit 1
        ;;
esac
